# .claudeignore — Context Budget Hard Filter
# Syntax: standard .gitignore glob patterns
# Purpose: Prevent agent from ingesting high-token, zero-signal paths
# Rule: When in doubt, exclude. Agent can be explicitly directed to read any file if needed.

# ────────────────────────────────────────────
# DEPENDENCY TREES (catastrophic token cost)
# ────────────────────────────────────────────
node_modules/
vendor/
.venv/
venv/
env/
__pypackages__/
.bundle/
Pods/

# ────────────────────────────────────────────
# LOCKFILES (dense, machine-generated, never reason over directly)
# ────────────────────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock
Gemfile.lock
Cargo.lock
go.sum
composer.lock
*.lock

# ────────────────────────────────────────────
# BUILD & COMPILE OUTPUT
# ────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
__pycache__/
*.pyc
*.pyo
*.class
*.o
*.obj
*.a
*.so
*.dll
*.exe
*.wasm
target/

# ────────────────────────────────────────────
# COVERAGE & TEST ARTIFACTS
# ────────────────────────────────────────────
coverage/
.coverage
lcov.info
*.lcov
htmlcov/
.nyc_output/
test-results/
junit*.xml

# ────────────────────────────────────────────
# LOGS & RUNTIME DATA (never ingest raw logs)
# ────────────────────────────────────────────
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
*.pid
*.seed

# ────────────────────────────────────────────
# GENERATED & COMPILED ASSETS
# ────────────────────────────────────────────
*.min.js
*.min.css
*.map
*.css.map
*.js.map
*.chunk.js
*.bundle.js
public/assets/
static/generated/

# ────────────────────────────────────────────
# BINARY & MEDIA FILES
# ────────────────────────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.webp
*.mp4
*.mp3
*.wav
*.pdf
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.bin
*.dat
*.db
*.sqlite
*.sqlite3

# ────────────────────────────────────────────
# SECRETS & CREDENTIALS (security-critical)
# ────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/
credentials/

# ────────────────────────────────────────────
# CI PIPELINE ARTIFACTS
# ────────────────────────────────────────────
.github/actions/*/node_modules/
*.sarif
security-scan-results/
sbom/
trivy-results/

# ────────────────────────────────────────────
# GENERATED PLANS & UPLOAD STAGING
# ────────────────────────────────────────────
uploads/
tmp/
temp/
.tmp/
generated-plans/
*.generated.*

# ────────────────────────────────────────────
# IDE & OS NOISE
# ────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/extensions/
*.swp
*.swo
.history/

# ────────────────────────────────────────────
# MONITORING DASHBOARDS (dense JSON — read targeted keys only)
# ────────────────────────────────────────────
*.dashboard.json
grafana-export/
